OMNITOKEN_GATEWAY_ADDR=:8080
OMNITOKEN_ADMIN_ADDR=:8081
OMNITOKEN_DATABASE_URL=postgres://omnitoken:omnitoken@localhost:15432/omnitoken?sslmode=disable
OMNITOKEN_REDIS_ADDR=localhost:16379
OMNITOKEN_NATS_URL=nats://localhost:14222
OMNITOKEN_LOG_BODY_MODE=off
OMNITOKEN_MASTER_KEY=

# Admin CORS allow-list (comma separated). Empty string means deny all cross-origin.
# Phase 1 admin API will reject any Origin not in this list (REVIEW.md H-1).
OMNITOKEN_ADMIN_CORS_ORIGINS=http://localhost:3000

# --- Upstream providers ---
# Volcano Engine Ark — dev/test only. Production must inject through KMS-backed secret store.
# OpenAI-compatible:   https://ark.cn-beijing.volces.com/api/coding/v3
# Anthropic-compatible: https://ark.cn-beijing.volces.com/api/coding
# Config alias: ark-code-latest (resolves upstream to glm-5.1, a reasoning model).
# Fastest stable recipe: OpenAI-compat + thinking.disabled + stream_options.include_usage=true (~1.8s round trip).
OMNITOKEN_ARK_API_KEY=
OMNITOKEN_ARK_OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OMNITOKEN_ARK_ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
OMNITOKEN_ARK_DEFAULT_MODEL=ark-code-latest
OMNITOKEN_ARK_DISABLE_THINKING=true
