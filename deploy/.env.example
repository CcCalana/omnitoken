# Copy to .env in this deploy/ directory, then fill the required values.

# === Security ===
# Required: 32-byte master key encoded as 64 hex chars. Example: openssl rand -hex 32
OMNITOKEN_MASTER_KEY=

# === Upstream API Keys (at least one key is required) ===
OMNITOKEN_DEEPSEEK_KEYS_1=
OMNITOKEN_DEEPSEEK_KEYS_2=
OMNITOKEN_DEEPSEEK_KEYS_3=
OMNITOKEN_ARK_KEYS_1=
OMNITOKEN_ARK_KEYS_2=
OMNITOKEN_ARK_KEYS_3=

# === Admin initial account ===
# Required: initial password for admin@democorp.local.
ADMIN_INITIAL_PASSWORD=

# === Domain and ports ===
# DOMAIN empty means nginx server_name _.
DOMAIN=localhost
GATEWAY_PORT=8080
ADMIN_PORT=8081
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === SSL (optional) ===
# Set both paths to enable HTTPS and HTTP -> HTTPS redirect.
# Leave both empty for pure HTTP.
SSL_CERT_PATH=
SSL_KEY_PATH=

# === Optional tuning ===
OMNITOKEN_ADMIN_SESSION_TTL=24h
OMNITOKEN_ADMIN_KEY_ANOMALY_RPM_5M=60
OMNITOKEN_CREDENTIAL_POLL_INTERVAL=30s
OMNITOKEN_LOG_BODY_MODE=off
OMNITOKEN_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OMNITOKEN_ARK_OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OMNITOKEN_ARK_ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
OMNITOKEN_ARK_DEFAULT_MODEL=ark-code-latest
OMNITOKEN_ARK_DISABLE_THINKING=true
