FROM golang:1.25-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
COPY cmd ./cmd
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/mockark ./cmd/loadtest/mockark

FROM alpine:3.20

COPY --from=build /out/mockark /mockark
EXPOSE 8090
USER 65532:65532
ENTRYPOINT ["/mockark"]
