FROM golang:1.25-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
COPY cmd ./cmd
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/omnitoken-migrate ./cmd/migrate

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /out/omnitoken-migrate /omnitoken-migrate
COPY migrations /migrations
USER nonroot:nonroot
ENTRYPOINT ["/omnitoken-migrate", "-path", "/migrations"]
